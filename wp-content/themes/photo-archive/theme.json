{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "palette": [
        { "slug": "bg",      "color": "#F8F7F4", "name": "Background" },
        { "slug": "surface", "color": "#FFFFFF", "name": "Surface" },
        { "slug": "border",  "color": "#E0DDD6", "name": "Border" },
        { "slug": "text",    "color": "#1A1917", "name": "Text" },
        { "slug": "muted",   "color": "#8A857D", "name": "Muted" },
        { "slug": "accent",  "color": "#C41E3A", "name": "Accent Red" }
      ],
      "defaultColors": false,
      "defaultDuotone": false,
      "defaultGradients": false
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Playfair Display', Georgia, serif",
          "slug": "display",
          "name": "Display"
        },
        {
          "fontFamily": "'IBM Plex Mono', 'Courier New', monospace",
          "slug": "mono",
          "name": "Mono"
        },
        {
          "fontFamily": "system-ui, -apple-system, sans-serif",
          "slug": "ui",
          "name": "UI"
        }
      ],
      "fontSizes": [
        { "slug": "xs",   "size": "0.75rem",  "name": "Extra Small" },
        { "slug": "sm",   "size": "0.875rem", "name": "Small" },
        { "slug": "base", "size": "1rem",     "name": "Base" },
        { "slug": "lg",   "size": "1.125rem", "name": "Large" },
        { "slug": "xl",   "size": "1.25rem",  "name": "Extra Large" },
        { "slug": "2xl",  "size": "1.5rem",   "name": "2X Large" },
        { "slug": "3xl",  "size": "1.875rem", "name": "3X Large" },
        { "slug": "4xl",  "size": "2.25rem",  "name": "4X Large" },
        { "slug": "5xl",  "size": "3rem",     "name": "5X Large" }
      ],
      "defaultFontSizes": false
    },
    "spacing": {
      "spacingSizes": [
        { "slug": "1", "size": "0.25rem",  "name": "1" },
        { "slug": "2", "size": "0.5rem",   "name": "2" },
        { "slug": "3", "size": "0.75rem",  "name": "3" },
        { "slug": "4", "size": "1rem",     "name": "4" },
        { "slug": "6", "size": "1.5rem",   "name": "6" },
        { "slug": "8", "size": "2rem",     "name": "8" },
        { "slug": "12", "size": "3rem",    "name": "12" },
        { "slug": "16", "size": "4rem",    "name": "16" },
        { "slug": "24", "size": "6rem",    "name": "24" }
      ],
      "defaultSpacingSizes": false
    },
    "layout": {
      "contentSize": "640px",
      "wideSize": "1200px"
    },
    "blocks": {
      "core/image": {
        "color": { "duotone": [] }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--bg)",
      "text": "var(--wp--preset--color--text)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--ui)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--8)"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontSize": "var(--wp--preset--font-size--4xl)",
          "fontWeight": "700",
          "lineHeight": "1.1"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontSize": "var(--wp--preset--font-size--3xl)",
          "fontWeight": "700"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "fontSize": "var(--wp--preset--font-size--sm)",
          "fontWeight": "500",
          "textTransform": "uppercase",
          "letterSpacing": "0.08em"
        }
      },
      "link": {
        "color": { "text": "var(--wp--preset--color--text)" },
        "typography": { "textDecoration": "none" },
        ":hover": {
          "color": { "text": "var(--wp--preset--color--accent)" }
        }
      }
    },
    "blocks": {
      "core/post-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)"
        }
      }
    }
  },
  "templateParts": [
    { "name": "header",        "title": "Header",        "area": "header" },
    { "name": "footer",        "title": "Footer",        "area": "footer" },
    { "name": "archive-row",   "title": "Archive Row",   "area": "uncategorized" }
  ],
  "customTemplates": [
    { "name": "single-photo",     "title": "Single Photo — Dossier",  "postTypes": ["photo"] },
    { "name": "single-story",     "title": "Single Story",            "postTypes": ["story"] },
    { "name": "archive-photo",    "title": "Archive — Photo Ledger",  "postTypes": ["photo"] },
    { "name": "taxonomy-series",  "title": "Series Archive",          "postTypes": ["photo", "story"] }
  ]
}
